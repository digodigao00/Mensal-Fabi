<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gestão de RH — Dashboard Mensal</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  :root {
    --azul:    #2E5BA8;
    --azul2:   #4A7FCB;
    --azullt:  #A8C4E8;
    --laranja: #E8873A;
    --bege:    #F5E6C8;
    --begest:  #EDD9A3;
    --rosa:    #F2A5A5;
    --verde:   #5DB88A;
    --cinza:   #F7F8FC;
    --texto:   #2C3346;
    --branco:  #FFFFFF;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--cinza);
    color: var(--texto);
    scroll-behavior: smooth;
  }

  /* ── NAVBAR ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(10px);
    border-bottom: 2px solid var(--bege);
    display: flex; align-items: center; gap: 6px;
    padding: 10px 32px;
    overflow-x: auto;
  }
  nav a {
    white-space: nowrap;
    text-decoration: none;
    font-weight: 700; font-size: 12px;
    color: var(--azul);
    padding: 6px 14px;
    border-radius: 20px;
    transition: all .2s;
  }
  nav a:hover, nav a.ativa { background: var(--azul); color: #fff; }
  .nav-titulo {
    font-family: 'Playfair Display', serif;
    font-weight: 900; font-size: 14px;
    color: var(--laranja);
    margin-right: 12px;
    border-right: 2px solid var(--bege);
    padding-right: 16px;
    white-space: nowrap;
  }

  /* ── SEÇÕES ── */
  section {
    min-height: 100vh;
    padding: 100px 40px 60px;
    position: relative;
    overflow: hidden;
  }

  .blob {
    position: absolute; border-radius: 50%; filter: blur(60px); opacity: .25; pointer-events: none;
  }

  /* ── CAPA ── */
  #capa {
    background: linear-gradient(135deg, #fff 55%, var(--bege) 100%);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; text-align: center; gap: 20px;
  }
  #capa .blob1 { width:400px; height:400px; background:var(--bege); top:-100px; left:-100px; }
  #capa .blob2 { width:300px; height:300px; background:var(--azullt); bottom:-80px; right:-60px; }
  .capa-dots {
    display: flex; gap: 8px; justify-content: center; margin-bottom: 20px;
  }
  .dot { width:18px; height:18px; border-radius:50%; }
  .capa-sub { font-size:13px; color:#999; font-weight:600; letter-spacing:4px; text-transform:uppercase; }
  .capa-titulo {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 900;
    line-height: 1.1;
  }
  .capa-titulo .hl-azul  { color: var(--azul); }
  .capa-titulo .hl-laranja { color: var(--laranja); }
  .capa-meta { font-size: 18px; font-weight: 700; color: #aaa; }
  .capa-autor { font-size: 16px; font-weight: 800; color: var(--azul); }
  .capa-divider { width: 60px; height: 3px; background: var(--laranja); border-radius: 2px; }

  /* ── CABEÇALHOS DE SEÇÃO ── */
  .sec-header { margin-bottom: 36px; }
  .sec-tag {
    display: inline-block;
    background: var(--bege);
    color: var(--laranja);
    font-size: 11px; font-weight: 800;
    letter-spacing: 3px; text-transform: uppercase;
    padding: 4px 14px; border-radius: 20px;
    margin-bottom: 8px;
  }
  .sec-titulo {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 900;
    color: var(--texto);
  }
  .sec-titulo span { color: var(--laranja); }

  /* ── GRID PESSOAS ── */
  .pessoas-grid {
    display: flex; flex-wrap: wrap; gap: 20px;
  }
  .pessoa-card {
    background: #fff;
    border-radius: 20px;
    padding: 24px 20px;
    text-align: center;
    width: 160px;
    box-shadow: 0 4px 20px rgba(0,0,0,.06);
    transition: transform .2s, box-shadow .2s;
    animation: fadeUp .5s ease both;
  }
  .pessoa-card:hover { transform: translateY(-4px); box-shadow: 0 10px 30px rgba(0,0,0,.12); }
  .pessoa-foto {
    width: 90px; height: 90px;
    border-radius: 50%; object-fit: cover;
    border: 3px solid var(--bege);
    margin: 0 auto 12px;
    display: block;
  }
  .pessoa-nome { font-weight: 800; font-size: 13px; line-height: 1.3; margin-bottom: 4px; }
  .pessoa-cargo { font-size: 11px; color: var(--laranja); font-weight: 600; }

  .badge-admitido  .pessoa-foto { border-color: var(--verde); }
  .badge-desligado .pessoa-foto { border-color: var(--rosa); }
  .badge-promovido .pessoa-foto { border-color: var(--laranja); }

  /* ── CARDS KPI ── */
  .kpi-row { display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 32px; }
  .kpi {
    background: #fff; border-radius: 16px;
    padding: 20px 24px; flex: 1; min-width: 140px;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
    border-left: 4px solid var(--azul);
  }
  .kpi.laranja { border-left-color: var(--laranja); }
  .kpi.verde   { border-left-color: var(--verde); }
  .kpi.rosa    { border-left-color: var(--rosa); }
  .kpi-valor { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 900; }
  .kpi-label { font-size: 12px; color: #888; font-weight: 600; margin-top: 2px; }

  /* ── GRÁFICOS ── */
  .charts-row { display: flex; flex-wrap: wrap; gap: 24px; }
  .chart-box {
    background: #fff; border-radius: 20px;
    padding: 24px; flex: 1; min-width: 280px;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }
  .chart-titulo { font-weight: 800; font-size: 14px; margin-bottom: 16px; color: var(--texto); }
  .chart-sub    { font-size: 12px; color: #999; font-weight: 600; margin-bottom: 12px; }

  canvas { max-height: 260px; }

  /* ── TABELA TURNOVER ── */
  .turnover-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead th {
    background: var(--azul); color: #fff;
    padding: 10px 12px; text-align: center; font-weight: 700;
  }
  tbody tr:nth-child(even) { background: var(--cinza); }
  tbody td { padding: 8px 12px; text-align: center; }
  tbody tr:hover { background: var(--bege); }
  .meta-ok   { color: var(--verde);   font-weight: 800; }
  .meta-fail { color: #e05050; font-weight: 800; }

  /* ── VALE REFEIÇÃO ── */
  .vr-grid { display: flex; flex-wrap: wrap; gap: 20px; }
  .vr-card {
    background: #fff; border-radius: 20px;
    padding: 24px; flex: 1; min-width: 260px;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }
  .vr-header {
    font-weight: 900; font-size: 15px; text-align: center;
    padding: 8px; border-radius: 10px; margin-bottom: 16px; color: #fff;
  }
  .vr-card:nth-child(1) .vr-header { background: var(--azullt); }
  .vr-card:nth-child(2) .vr-header { background: var(--laranja); }
  .vr-card:nth-child(3) .vr-header { background: #c084fc; }
  .vr-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f0f0f0; font-size: 13px; }
  .vr-total { font-weight: 900; font-size: 16px; text-align: right; margin-top: 12px; color: var(--azul); }

  /* ── PROMOÇÃO SETOR ── */
  .promo-card {
    background: linear-gradient(135deg, var(--bege), #fff);
    border-radius: 24px; padding: 40px;
    display: flex; align-items: center; gap: 40px;
    flex-wrap: wrap;
    box-shadow: 0 4px 24px rgba(0,0,0,.08);
    max-width: 600px;
  }
  .promo-foto {
    width: 120px; height: 120px; border-radius: 50%;
    object-fit: cover; border: 4px solid var(--laranja);
  }
  .promo-info h3 { font-size: 22px; font-weight: 900; margin-bottom: 6px; }
  .promo-info p  { font-size: 14px; color: #666; margin: 3px 0; }
  .promo-info .promo-setor { color: var(--laranja); font-weight: 800; font-size: 16px; }

  /* ── CONSIDERAÇÕES ── */
  #consideracoes {
    background: linear-gradient(135deg, #EAF1FB 0%, var(--bege) 100%);
    display: flex; align-items: center; justify-content: center; text-align: center;
  }
  .consid-inner { max-width: 600px; }
  .consid-inner h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 5vw, 56px); font-weight: 900;
    color: var(--azul); margin-bottom: 20px;
  }
  .consid-inner p { font-size: 18px; color: #555; line-height: 1.7; margin-bottom: 12px; }
  .consid-autor { font-weight: 900; font-size: 20px; color: var(--laranja); margin-top: 30px; }

  /* ── ANIMAÇÕES ── */
  @keyframes fadeUp {
    from { opacity:0; transform: translateY(20px); }
    to   { opacity:1; transform: translateY(0); }
  }
  .anim { animation: fadeUp .6s ease both; }

  /* ── PERCENTUAIS DESTAQUE ── */
  .pct-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 16px; }
  .pct-badge {
    background: var(--azul); color: #fff;
    border-radius: 12px; padding: 12px 20px;
    font-weight: 800; font-size: 13px;
    display: flex; flex-direction: column; align-items: center; gap: 4px;
  }
  .pct-badge .pct-num { font-size: 24px; font-family: 'Playfair Display', serif; }
  .pct-badge.laranja { background: var(--laranja); }
  .pct-badge.rosa    { background: var(--rosa); color: var(--texto); }

  @media (max-width: 600px) {
    section { padding: 90px 20px 50px; }
    .promo-card { flex-direction: column; text-align: center; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav id="navbar">
  <span class="nav-titulo">RH Dashboard</span>
  <a href="#capa">Início</a>
  <a href="#admitidos">Admitidos</a>
  <a href="#desligados">Desligados</a>
  <a href="#promovidos">Promovidos</a>


  <a href="#turnover">Turnover</a>
  <a href="#rs">R&amp;S</a>
  <a href="#sla">SLA</a>
  <a href="#vr">Vale Refeição</a>
  <a href="#promo-setor">Promoção</a>
  <a href="#consideracoes">Considerações</a>
</nav>

<!-- CAPA -->
<section id="capa">
  <div class="blob blob1"></div>
  <div class="blob blob2"></div>
  <div class="capa-dots">
    <div class="dot" style="background:var(--azul)"></div>
    <div class="dot" style="background:var(--laranja)"></div>
    <div class="dot" style="background:var(--azullt)"></div>
    <div class="dot" style="background:var(--begest)"></div>
  </div>
  <p class="capa-sub">Relatório Mensal</p>
  <h1 class="capa-titulo">
    <span class="hl-azul">Gestão de</span><br>
    <span class="hl-laranja">Recursos Humanos</span>
  </h1>
  <div class="capa-divider"></div>
  <p class="capa-meta" id="capa-mes-ano">—</p>
  <p class="capa-autor" id="capa-autor">—</p>
</section>

<!-- ADMITIDOS -->
<section id="admitidos" style="background:#fff;">
  <div class="sec-header">
    <div class="sec-tag">Movimentação</div>
    <h2 class="sec-titulo">✨ <span>Admitidos</span></h2>
  </div>
  <div class="pessoas-grid" id="grid-admitidos"></div>
</section>

<!-- DESLIGADOS -->
<section id="desligados" style="background:var(--cinza);">
  <div class="sec-header">
    <div class="sec-tag">Movimentação</div>
    <h2 class="sec-titulo">Desligados</h2>
  </div>
  <div class="pessoas-grid" id="grid-desligados"></div>
</section>

<!-- PROMOVIDOS -->
<section id="promovidos" style="background:#fff;">
  <div class="sec-header">
    <div class="sec-tag">Reconhecimento</div>
    <h2 class="sec-titulo"><span>Promovidos!!</span></h2>
  </div>
  <div class="pessoas-grid" id="grid-promovidos"></div>
</section>

<!-- TURNOVER -->
<section id="turnover" style="background:var(--cinza);">
  <div class="sec-header">
    <div class="sec-tag">Indicadores</div>
    <h2 class="sec-titulo"><span>Turnover</span></h2>
  </div>
  <div class="kpi-row" id="kpi-turnover"></div>
  <div class="charts-row" style="margin-bottom:32px;">
    <div class="chart-box">
      <p class="chart-titulo">Estagiários — Admissões vs Desligamentos</p>
      <canvas id="chartTurnEst"></canvas>
    </div>
    <div class="chart-box">
      <p class="chart-titulo">CLTs e PJs — Admissões vs Desligamentos</p>
      <canvas id="chartTurnClt"></canvas>
    </div>
  </div>
  <div class="charts-row">
    <div class="chart-box turnover-wrap" style="flex:2; min-width:280px;">
      <p class="chart-titulo">Controle de Turnover — Estagiários</p>
      <table id="tabela-turnover-est"></table>
    </div>
    <div class="chart-box turnover-wrap" style="flex:2; min-width:280px;">
      <p class="chart-titulo">Controle de Turnover — CLTs e PJs</p>
      <table id="tabela-turnover-clt"></table>
    </div>
  </div>
</section>

<!-- R&S -->
<section id="rs" style="background:#fff;">
  <div class="sec-header">
    <div class="sec-tag">Recrutamento &amp; Seleção</div>
    <h2 class="sec-titulo">Processo <span>Seletivo</span></h2>
  </div>
  <div class="pct-row" id="rs-pct"></div>
  <div class="charts-row" style="margin-top:32px;">
    <div class="chart-box" style="flex:2;">
      <p class="chart-titulo">Acompanhamento do Funil Seletivo</p>
      <canvas id="chartFunil"></canvas>
    </div>
  </div>
  <div class="charts-row" style="margin-top:24px;">
    <div class="chart-box">
      <p class="chart-titulo">Aprovações, Contratações e Stands</p>
      <canvas id="chartContrat"></canvas>
    </div>
    <div class="chart-box">
      <p class="chart-titulo">Entrevistas por Recrutador</p>
      <canvas id="chartRecrutador"></canvas>
    </div>
  </div>
  <div class="charts-row" style="margin-top:24px;">
    <div class="chart-box" style="flex:2;">
      <p class="chart-titulo">Currículos por Plataforma</p>
      <canvas id="chartPlataforma"></canvas>
    </div>
  </div>
</section>

<!-- SLA -->
<section id="sla" style="background:var(--cinza);">
  <div class="sec-header">
    <div class="sec-tag">SLA</div>
    <h2 class="sec-titulo">SLA — <span>Pesquisadores</span></h2>
  </div>
  <div class="kpi-row" id="kpi-sla"></div>
  <div class="charts-row">
    <div class="chart-box">
      <p class="chart-titulo">Vagas do Mês</p>
      <canvas id="chartSlaVagas"></canvas>
    </div>
    <div class="chart-box">
      <p class="chart-titulo">SLA por Pesquisador</p>
      <canvas id="chartSlaPesq"></canvas>
    </div>
    <div class="chart-box">
      <p class="chart-titulo">SLA por Região</p>
      <canvas id="chartSlaRegiao"></canvas>
    </div>
  </div>
</section>

<!-- VALE REFEIÇÃO -->
<section id="vr" style="background:#fff;">
  <div class="sec-header">
    <div class="sec-tag">Benefícios</div>
    <h2 class="sec-titulo">Vale <span>Refeição</span></h2>
  </div>
  <div class="vr-grid" id="vr-grid"></div>
</section>

<!-- PROMOÇÃO PARA O SETOR -->
<section id="promo-setor" style="background:var(--cinza);">
  <div class="sec-header">
    <div class="sec-tag">Promoção</div>
    <h2 class="sec-titulo">Promoção para o <span>Setor</span></h2>
  </div>
  <div id="promo-setor-grid" style="display:flex;flex-wrap:wrap;gap:24px;"></div>
</section>

<!-- CONSIDERAÇÕES FINAIS -->
<section id="consideracoes">
  <div class="consid-inner anim">
    <h2>Considerações Finais</h2>
    <p>Contrato de sigilo e ajuda de custo (VR) — Consultar advogado</p>
    <div class="consid-autor" id="consid-autor">—</div>
  </div>
</section>

<script>
/* =====================================================
   CARREGA dados.json e POPULA TUDO
   ===================================================== */
async function init() {
  let d;
  try {
    const base = window.location.pathname.replace(/\/[^/]*$/, '/');
    const r = await fetch(base + 'dados.json');
    d = await r.json();
  } catch(e) {
    alert('Não foi possível carregar dados.json. Certifique-se que o arquivo está na mesma pasta.');
    return;
  }

  // ── CAPA ──
  document.getElementById('capa-mes-ano').textContent = `${d.mes} / ${d.ano}`;
  document.getElementById('capa-autor').textContent   = d.responsavel;
  document.getElementById('consid-autor').textContent = d.responsavel;
  document.title = `RH — ${d.mes}/${d.ano}`;

  // ── PESSOAS ──
  renderPessoas('grid-admitidos',  d.admitidos,  'badge-admitido');
  renderPessoas('grid-desligados', d.desligados, 'badge-desligado');
  renderPessoas('grid-promovidos', d.promovidos, 'badge-promovido');

  // ── TURNOVER ──
  renderTurnover(d.turnover, d);

  // ── R&S ──
  renderRS(d.recrutamento);

  // ── SLA ──
  renderSLA(d.sla);

  // ── VR ──
  renderVR(d.valeRefeicao);

  // ── PROMOÇÃO SETOR ──
  renderPromoSetor(d.promocaoSetor);

  // ── NAV ATIVA ──
  navScroll();
}

/* ── PESSOAS ── */
function renderPessoas(id, lista, cls) {
  const el = document.getElementById(id);
  el.innerHTML = lista.map((p, i) => `
    <div class="pessoa-card ${cls}" style="animation-delay:${i*0.07}s">
      <img class="pessoa-foto" src="${p.foto}" alt="${p.nome}" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(p.nome)}&background=E8873A&color=fff&size=90'">
      <p class="pessoa-nome">${p.nome}</p>
      <p class="pessoa-cargo">${p.cargo}</p>
    </div>`).join('');
}

/* ── TURNOVER ── */
function calcTurnover(row) {
  if (!row.colaboradores || row.colaboradores === 0) return 0;
  return ((row.admissoes + row.desligamentos) / (2 * row.colaboradores) * 100);
}

function renderTurnoverTabela(idTabela, dados, meta) {
  const meses = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  let acc = 0; let count = 0;
  const rows = dados.map((row, i) => {
    const tv = calcTurnover(row);
    if (row.colaboradores > 0) { acc += tv; count++; }
    const media = count > 0 ? (acc / count) : 0;
    const cls = tv > 0 ? (tv > meta ? 'meta-fail' : 'meta-ok') : '';
    return `<tr>
      <td>${meses[i]}</td>
      <td>${row.admissoes || ''}</td>
      <td>${row.desligamentos || ''}</td>
      <td>${row.colaboradores || ''}</td>
      <td class="${cls}">${tv > 0 ? tv.toFixed(2)+'%' : '0,00%'}</td>
      <td>${media.toFixed(2)}%</td>
      <td>${meta}%</td>
    </tr>`;
  }).join('');
  document.getElementById(idTabela).innerHTML = `
    <thead><tr>
      <th>Mês</th><th>Admissões</th><th>Desligamentos</th>
      <th>Colaboradores</th><th>Turnover</th><th>Média Acum.</th><th>Meta</th>
    </tr></thead>
    <tbody>${rows}</tbody>`;
}

function renderTurnover(tv, d) {
  const meses = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  const adEst = tv.estagiarios.map(r => r.admissoes);
  const dlEst = tv.estagiarios.map(r => r.desligamentos);
  const adClt = tv.clts.map(r => r.admissoes);
  const dlClt = tv.clts.map(r => r.desligamentos);

  // KPIs do mês atual
  const mesIdx = new Date().getMonth();
  const estMes = tv.estagiarios[mesIdx];
  const cltMes = tv.clts[mesIdx];
  document.getElementById('kpi-turnover').innerHTML = `
    <div class="kpi"><div class="kpi-valor">${d.admitidos.length}</div><div class="kpi-label">Admitidos no mês</div></div>
    <div class="kpi laranja"><div class="kpi-valor">${d.desligados.length}</div><div class="kpi-label">Desligados no mês</div></div>
    <div class="kpi verde"><div class="kpi-valor">${d.promovidos.length}</div><div class="kpi-label">Promovidos</div></div>
    <div class="kpi rosa"><div class="kpi-valor">${tv.meta}%</div><div class="kpi-label">Meta de Turnover</div></div>`;

  makeBarChart('chartTurnEst', meses, [
    { label:'Admissões',    data: adEst, color: '#4A7FCB' },
    { label:'Desligamentos',data: dlEst, color: '#E8873A' }
  ]);
  makeBarChart('chartTurnClt', meses, [
    { label:'Admissões',    data: adClt, color: '#4A7FCB' },
    { label:'Desligamentos',data: dlClt, color: '#E8873A' }
  ]);

  renderTurnoverTabela('tabela-turnover-est', tv.estagiarios, tv.meta);
  renderTurnoverTabela('tabela-turnover-clt', tv.clts, tv.meta);
}

/* ── R&S ── */
function renderRS(rs) {
  const f = rs.funil;
  const pctAg = f.entrevistasAgendadas > 0 ? (f.entrevistasRealizadas / f.entrevistasAgendadas * 100).toFixed(2) : 0;
  const pctTe = f.testesMarcados > 0 ? (f.testesRealizados / f.testesMarcados * 100).toFixed(2) : 0;
  const pctCa = f.testesMarcados > 0 ? ((f.desistenciaTeste / f.testesMarcados) * 100).toFixed(2) : 0;

  document.getElementById('rs-pct').innerHTML = `
    <div class="pct-badge"><span class="pct-num">${pctAg}%</span>Agendadas x Realizadas — Entrevistas</div>
    <div class="pct-badge laranja"><span class="pct-num">${pctTe}%</span>Marcados x Realizados — Testes</div>
    <div class="pct-badge rosa"><span class="pct-num">${pctCa}%</span>Marcados x Cancelados — Testes</div>`;

  // Funil
  const funil = {
    labels: ['Entrevistas\nAgendadas','Entrevistas\nRealizadas','Aprovados\nEntrevista','Testes\nMarcados','Desistência\nTeste','Reprovados','Desist.\nAjuda Custo','Desist.\nPós Entrevista','Testes\nRealizados'],
    data:   [f.entrevistasAgendadas, f.entrevistasRealizadas, f.aprovadosEntrevista, f.testesMarcados, f.desistenciaTeste, f.reprovados, f.desistenciaAjudaCusto, f.desistenciaPosEntrevista, f.testesRealizados]
  };
  makeSingleBarChart('chartFunil', funil.labels, funil.data, '#4A7FCB', '#A8C4E8');

  // Contratações
  const c = rs.contratacoes;
  makeSingleBarChart('chartContrat',
    ['Contratados','MEI','Freela','Stand By','Desistência\nContratação'],
    [c.contratados, c.mei, c.freela, c.standBy, c.desistenciaContratacao],
    '#4A7FCB', '#A8C4E8');

  // Recrutador
  makeBarChart('chartRecrutador', rs.porRecrutador.map(r=>r.nome), [
    { label:'Agendadas', data: rs.porRecrutador.map(r=>r.agendadas), color:'#4A7FCB' },
    { label:'Realizadas', data: rs.porRecrutador.map(r=>r.realizadas), color:'#A8C4E8' }
  ]);

  // Plataforma
  makeBarChart('chartPlataforma', rs.porPlataforma.map(p=>p.plataforma), [
    { label:'Total Mês', data: rs.porPlataforma.map(p=>p.mes), color:'#4A7FCB' },
    { label:'Total Ano', data: rs.porPlataforma.map(p=>p.ano), color:'#A8C4E8' }
  ]);
}

/* ── SLA ── */
function renderSLA(sla) {
  document.getElementById('kpi-sla').innerHTML = `
    <div class="kpi"><div class="kpi-valor">${sla.total}</div><div class="kpi-label">SLA Total (dias)</div></div>
    <div class="kpi laranja"><div class="kpi-valor">${sla.vagasMes}</div><div class="kpi-label">Vagas no Mês</div></div>
    <div class="kpi verde"><div class="kpi-valor">${sla.vagasPreenchidas}</div><div class="kpi-label">Vagas Preenchidas</div></div>
    <div class="kpi rosa"><div class="kpi-valor">${sla.vagasRecrutamento}</div><div class="kpi-label">Em Recrutamento</div></div>`;

  makeSingleBarChart('chartSlaVagas',
    ['Vagas/mês','Vagas Preenchidas','Em Recrutamento'],
    [sla.vagasMes, sla.vagasPreenchidas, sla.vagasRecrutamento],
