/* ── VR ── */
function fmt(v) { return v.toLocaleString('pt-BR',{style:'currency',currency:'BRL'}); }

function vrCenario(c, titulo, vr) {
  const linhas = [];
  if (vr.clts) {
    const total = vr.clts.qtd * vr.clts.valorDia * vr.clts.diasMes;
    linhas.push(`<div class="vr-row"><span>CLTs (${vr.clts.qtd})</span><span>${fmt(vr.clts.valorDia)}/dia × ${vr.clts.diasMes}d = ${fmt(total)}</span></div>`);
  }
  if (vr.estagiarios) {
    const total = vr.estagiarios.qtd * vr.estagiarios.valorDia * vr.estagiarios.diasMes;
    linhas.push(`<div class="vr-row"><span>Estagiários (${vr.estagiarios.qtd})</span><span>${fmt(vr.estagiarios.valorDia)}/dia × ${vr.estagiarios.diasMes}d = ${fmt(total)}</span></div>`);
  }
  const totClt = vr.clts ? vr.clts.qtd * vr.clts.valorDia * vr.clts.diasMes : 0;
  const totEst = vr.estagiarios ? vr.estagiarios.qtd * vr.estagiarios.valorDia * vr.estagiarios.diasMes : 0;
  return `<div class="vr-card">
    <div class="vr-header">${titulo}</div>
    ${linhas.join('')}
    <div class="vr-total">Total: ${fmt(totClt + totEst)}</div>
  </div>`;
}

function renderVR(vr) {
  document.getElementById('vr-grid').innerHTML =
    vrCenario(1, 'Cenário 1', vr.cenario1) +
    vrCenario(2, 'Cenário 2', vr.cenario2) +
    vrCenario(3, 'Cenário 3', vr.cenario3);
}

